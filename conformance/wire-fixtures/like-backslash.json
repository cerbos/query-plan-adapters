{
  "action": "like-backslash",
  "resourceKind": "adversarial",
  "filter": {
    "kind": "KIND_CONDITIONAL",
    "condition": {
      "expression": {
        "operator": "endsWith",
        "operands": [
          {
            "variable": "request.resource.attr.aString"
          },
          {
            "value": "\\"
          }
        ]
      }
    }
  }
}
